// Prisma schema — single source of truth for database structure.
// Prisma generates a type-safe client from these models.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── User ───────────────────────────────────────────────────────────────────
// Core identity for authentication and expense participation.

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String   // bcrypt hash — never store plain text
  createdAt DateTime @default(now())

  createdGroups         Group[]
  groupMemberships      GroupMember[]
  expensesPaid          Expense[]              @relation("ExpensePayer")
  expenseParticipations ExpenseParticipant[]
  settlementsPaid       Settlement[]           @relation("SettlementPayer")
  settlementsReceived   Settlement[]           @relation("SettlementReceiver")
}

// ─── Group ──────────────────────────────────────────────────────────────────
// A shared expense bucket (e.g. "Roommates", "Trip to Goa").

model Group {
  id        Int      @id @default(autoincrement())
  name      String
  createdBy Int
  createdAt DateTime @default(now())

  creator  User          @relation(fields: [createdBy], references: [id])
  members  GroupMember[]
  expenses Expense[]
}

// ─── GroupMember ────────────────────────────────────────────────────────────
// Membership is never hard-deleted — leftAt marks when someone left the group.

model GroupMember {
  id       Int       @id @default(autoincrement())
  groupId  Int
  userId   Int
  joinedAt DateTime  @default(now())
  leftAt   DateTime? // null = still active in the group

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
}

// ─── Expense ─────────────────────────────────────────────────────────────────
// A single bill or purchase within a group.

model Expense {
  id          Int      @id @default(autoincrement())
  groupId     Int
  title       String
  amount      Decimal  @db.Decimal(10, 2)
  currency    Currency @default(INR)
  paidBy      Int
  expenseDate DateTime
  splitType   SplitType

  group        Group                @relation(fields: [groupId], references: [id], onDelete: Cascade)
  payer        User                 @relation("ExpensePayer", fields: [paidBy], references: [id])
  participants ExpenseParticipant[]
}

enum Currency {
  INR
  USD
}

enum SplitType {
  EQUAL
  EXACT
  PERCENTAGE
  SHARE
}

// ─── ExpenseParticipant ─────────────────────────────────────────────────────
// One row per person involved in an expense split.

model ExpenseParticipant {
  id          Int     @id @default(autoincrement())
  expenseId   Int
  userId      Int
  shareAmount Decimal @db.Decimal(10, 2)

  expense Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([expenseId, userId])
}

// ─── Settlement ─────────────────────────────────────────────────────────────
// Kept for future balance/settlement APIs — not implemented in Part 1–4.

model Settlement {
  id          Int      @id @default(autoincrement())
  payerId     Int
  receiverId  Int
  amount      Decimal  @db.Decimal(10, 2)
  paymentDate DateTime @default(now())

  payer    User @relation("SettlementPayer", fields: [payerId], references: [id])
  receiver User @relation("SettlementReceiver", fields: [receiverId], references: [id])
}
