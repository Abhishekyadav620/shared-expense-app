generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

//////////////////////////////////////////////////
// ENUMS
//////////////////////////////////////////////////

enum Currency {
  INR
  USD
}

enum SplitType {
  EQUAL
  EXACT
  PERCENTAGE
  SHARE
}

//////////////////////////////////////////////////
// USER
//////////////////////////////////////////////////

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())

  // Relations
  createdGroups         Group[]              @relation("GroupCreator")
  groupMemberships      GroupMember[]
  expensesPaid          Expense[]            @relation("ExpensePayer")
  expenseParticipations ExpenseParticipant[]
  settlementsPaid       Settlement[]         @relation("SettlementPayer")
  settlementsReceived   Settlement[]         @relation("SettlementReceiver")
  importReports         ImportReport[]
}

//////////////////////////////////////////////////
// GROUP
//////////////////////////////////////////////////

model Group {
  id        Int      @id @default(autoincrement())
  name      String
  createdBy Int
  createdAt DateTime @default(now())

  // Relations
  creator     User          @relation("GroupCreator", fields: [createdBy], references: [id])
  members     GroupMember[]
  expenses    Expense[]
  settlements Settlement[]
  importReports ImportReport[]
}

//////////////////////////////////////////////////
// GROUP MEMBER
//////////////////////////////////////////////////

model GroupMember {
  id       Int       @id @default(autoincrement())
  groupId  Int
  userId   Int
  joinedAt DateTime  @default(now())
  leftAt   DateTime?

  // Relations
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
}

//////////////////////////////////////////////////
// EXPENSE
//////////////////////////////////////////////////

model Expense {
  id          Int       @id @default(autoincrement())
  groupId     Int
  title       String
  amount      Decimal   @db.Decimal(10, 2)
  currency    Currency  @default(INR)
  paidBy      Int
  expenseDate DateTime
  splitType   SplitType

  // Relations
  group        Group                @relation(fields: [groupId], references: [id], onDelete: Cascade)
  payer        User                 @relation("ExpensePayer", fields: [paidBy], references: [id])
  participants ExpenseParticipant[]
}

//////////////////////////////////////////////////
// EXPENSE PARTICIPANT
//////////////////////////////////////////////////

model ExpenseParticipant {
  id          Int     @id @default(autoincrement())
  expenseId   Int
  userId      Int
  shareAmount Decimal @db.Decimal(10, 2)

  // Relations
  expense Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([expenseId, userId])
}

//////////////////////////////////////////////////
// SETTLEMENT
//////////////////////////////////////////////////

model Settlement {
  id          Int      @id @default(autoincrement())
  groupId     Int
  payerId     Int
  receiverId  Int
  amount      Decimal  @db.Decimal(10, 2)
  paymentDate DateTime @default(now())

  // Relations
  group    Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  payer    User  @relation("SettlementPayer", fields: [payerId], references: [id])
  receiver User  @relation("SettlementReceiver", fields: [receiverId], references: [id])
}

//////////////////////////////////////////////////
// IMPORT REPORTING
//////////////////////////////////////////////////

model ImportReport {
  id                Int      @id @default(autoincrement())
  groupId           Int
  userId            Int
  totalRows         Int
  successfulImports Int
  skippedRows       Int
  anomalyCount      Int
  usdToInrRate      Decimal? @db.Decimal(10, 4)
  reportJson        Json
  createdAt         DateTime @default(now())

  group     Group           @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  anomalies ImportAnomaly[]
  reviews   ImportReview[]
}

model ImportAnomaly {
  id              Int    @id @default(autoincrement())
  importReportId  Int
  rowNumber       Int
  issueType       String
  severity        String
  description     String @db.Text
  suggestedAction String @db.Text

  importReport ImportReport @relation(fields: [importReportId], references: [id], onDelete: Cascade)
}

model ImportReview {
  id             Int    @id @default(autoincrement())
  importReportId Int
  rowNumber      Int
  issueType      String
  actionTaken    String

  importReport ImportReport @relation(fields: [importReportId], references: [id], onDelete: Cascade)
}

